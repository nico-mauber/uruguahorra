# ==================== ANALYTICS CONFIGURATION ====================
# Analytics feature toggles
EXPO_PUBLIC_ANALYTICS_ENABLED=true
EXPO_PUBLIC_PSYCHOLOGICAL_INSIGHTS_ENABLED=true
EXPO_PUBLIC_SPENDING_FORECAST_ENABLED=true

# Cache and performance settings
EXPO_PUBLIC_ANALYTICS_CACHE_INTERVAL=300000
EXPO_PUBLIC_ANALYTICS_BACKGROUND_REFRESH=900000
EXPO_PUBLIC_ANALYTICS_API_TIMEOUT=5000

# Data validation settings
EXPO_PUBLIC_MIN_TRANSACTIONS_FOR_INSIGHTS=5
EXPO_PUBLIC_MIN_DAYS_OF_DATA=7
EXPO_PUBLIC_MAX_INSIGHTS_DISPLAY=4

# Development settings
EXPO_PUBLIC_ANALYTICS_DEBUG_MODE=false
EXPO_PUBLIC_ANALYTICS_MOCK_FALLBACK=true
EXPO_PUBLIC_ANALYTICS_VERBOSE_LOGGING=false

# Trending and analysis thresholds
EXPO_PUBLIC_UP_TREND_THRESHOLD=1.1
EXPO_PUBLIC_DOWN_TREND_THRESHOLD=0.9
EXPO_PUBLIC_HIGH_IMPACT_THRESHOLD=0.2

# UI Configuration
EXPO_PUBLIC_REFRESH_ANIMATION_DURATION=300
EXPO_PUBLIC_TAB_ANIMATION_DURATION=200

# Language and localization
EXPO_PUBLIC_DEFAULT_LANGUAGE=es
EXPO_PUBLIC_DEFAULT_CURRENCY=UYU
EXPO_PUBLIC_DEFAULT_DATE_FORMAT=DD/MM/YYYY

# Feature flags for upcoming features
EXPO_PUBLIC_ENABLE_EXPORT_FUNCTIONALITY=false
EXPO_PUBLIC_ENABLE_CUSTOM_CATEGORIES=false
EXPO_PUBLIC_EXPERIMENTAL_AI_INSIGHTS=false