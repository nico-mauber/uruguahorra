{
  "expo": {
    "name": "Uruguahorra",
    "slug": "uruguahorra-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "uruguahorra",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.uruguahorra.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366F1"
      },
      "package": "com.uruguahorra.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "buildDir": "web-build",
      "name": "Uruguahorra - App de Ahorro",
      "shortName": "Uruguahorra",
      "description": "App móvil de ahorro gamificada para desarrollar hábitos de ahorro mediante gamificación, metas y retos.",
      "lang": "es",
      "scope": "/",
      "startUrl": "/",
      "display": "standalone",
      "orientation": "portrait",
      "themeColor": "#6366F1",
      "backgroundColor": "#ffffff",
      "preferRelatedApplications": false,
      "crossorigin": "use-credentials",
      "config": {
        "firebase": {
          "authDomain": "uruguahorra.firebaseapp.com",
          "databaseURL": "https://uruguahorra.firebaseio.com",
          "projectId": "uruguahorra",
          "storageBucket": "uruguahorra.appspot.com",
          "messagingSenderId": "123456789",
          "appId": "1:123456789:web:abc123"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-localization"
    ],
    "extra": {
      "appVersion": "1.0.0",
      "posthogKey": "phc_Bpl5uyxSSfEXZelS6NlzphDCTwrhI1mhbGoItaoriTx"
    }
  }
}
