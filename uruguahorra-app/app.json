{
  "expo": {
    "name": "Uruguahorra",
    "slug": "uruguahorra-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "uruguahorra",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.uruguahorra.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Esta app necesita acceso al micrófono para crear transacciones por voz"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366F1"
      },
      "package": "com.uruguahorra.app",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED", 
        "WAKE_LOCK", 
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "buildDir": "web-build",
      "name": "Uruguahorra - App de Ahorro",
      "shortName": "Uruguahorra",
      "description": "App móvil de ahorro gamificada para desarrollar hábitos de ahorro mediante gamificación, metas y retos.",
      "lang": "es",
      "scope": "/",
      "startUrl": "/",
      "display": "standalone",
      "orientation": "portrait",
      "themeColor": "#6366F1",
      "backgroundColor": "#ffffff",
      "preferRelatedApplications": false,
      "crossorigin": "use-credentials",
      "config": {
        "firebase": {
          "authDomain": "uruguahorra.firebaseapp.com",
          "databaseURL": "https://uruguahorra.firebaseio.com",
          "projectId": "uruguahorra",
          "storageBucket": "uruguahorra.appspot.com",
          "messagingSenderId": "123456789",
          "appId": "1:123456789:web:abc123"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-av",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6366F1",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "appVersion": "1.0.0",
      "posthogKey": "phc_Bpl5uyxSSfEXZelS6NlzphDCTwrhI1mhbGoItaoriTx"
    }
  }
}
