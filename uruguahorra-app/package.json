{
  "name": "uruguahorra-app",
  "version": "1.0.0",
  "main": "./index.js",
  "scripts": {
    "start": "node node_modules/expo/bin/cli start",
    "android": "node node_modules/expo/bin/cli start --android",
    "ios": "node node_modules/expo/bin/cli start --ios",
    "web": "node node_modules/expo/bin/cli start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "test": "jest",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "build:web": "npx expo export --platform web",
    "generate-sw": "workbox generateSW workbox-config.js",
    "build:pwa": "npm run build:web && npm run generate-sw",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "functions:serve": "supabase functions serve billing-webhooks",
    "functions:deploy": "supabase functions deploy billing-webhooks",
    "billing:setup": "node scripts/setup-billing.bat",
    "billing:test": "echo \"Ejecuta las pruebas desde docs/billing-testing.md\"",
    "mcp:server": "node scripts/mcp-server-example.js",
    "mcp:install": "npm install express cors helmet compression morgan"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@supabase/supabase-js": "^2.56.0",
    "ajv": "^8.17.1",
    "expo": "~54.0.0",
    "expo-application": "~6.1.5",
    "expo-av": "~15.1.7",
    "expo-cli": "^6.3.12",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.7",
    "expo-device": "~7.1.4",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-linking": "~7.1.7",
    "expo-localization": "~16.1.6",
    "expo-notifications": "~0.31.4",
    "expo-router": "~5.1.6",
    "expo-secure-store": "~14.2.4",
    "expo-status-bar": "~2.2.3",
    "posthog-react-native": "^4.4.1",
    "react": "19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "0.79.5",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "^15.8.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.1",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.0.10",
    "@types/react-native": "^0.72.8",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "jest": "^29.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "~5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "overrides": {
    "react-test-renderer": "18.3.1"
  },
  "private": true
}
